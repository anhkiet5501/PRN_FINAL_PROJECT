# =====================================================
# Sao chép file này thành .env và điền các giá trị
# Copy this file to .env and fill in your values
# =====================================================

# DATABASE — Docker SQL Server
# Password phải đáp ứng: ≥8 ký tự, có chữ hoa, chữ thường, số và ký tự đặc biệt
# Password must meet: ≥8 chars, uppercase, lowercase, digit, special char
DB_SA_PASSWORD=<YourStrong@Passw0rd>
DB_SERVER=localhost,1433
DB_NAME=RagLmsDb

# API KEYS
# Lấy Gemini API Key miễn phí tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<your_gemini_api_key>
HUGGINGFACE_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
