@page "{sessionId:int?}"
@model PRN222_Assignment2.Pages.Chat.IndexModel
@{
    ViewData["Title"] = "Chat RAG";
    ViewData["ActivePage"] = "Chat";
}

<style>
/* ═══════════════════════════════════════════════════════════
   CHAT PAGE — Premium RAG Chat Interface
   ═══════════════════════════════════════════════════════════ */

/* Layout */
.chat-page-wrapper {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 0;
    height: calc(100vh - var(--header-height) - 2rem);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border);
}

/* ── Sidebar ──────────────────────────────────── */
.chat-sidebar {
    background: var(--sidebar-bg);
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.chat-sidebar-header {
    padding: 1rem 1rem 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
}

.chat-sidebar-header h3 {
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
}

.btn-new-chat {
    width: 32px; height: 32px;
    border-radius: 8px;
    background: var(--accent);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem;
    transition: background 0.15s, transform 0.1s;
    flex-shrink: 0;
}
.btn-new-chat:hover { background: var(--accent-hover); transform: scale(1.08); }

.sessions-list {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}
.sessions-list::-webkit-scrollbar { width: 4px; }
.sessions-list::-webkit-scrollbar-track { background: transparent; }
.sessions-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 999px; }

.session-card {
    padding: 0.65rem 0.85rem;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s;
    border: 1px solid transparent;
}
.session-card:hover {
    background: rgba(255,255,255,0.07);
}
.session-card.active {
    background: rgba(30, 136, 229, 0.25);
    border-color: rgba(30, 136, 229, 0.4);
}
.session-card .s-title {
    color: #e2e8f0;
    font-size: 0.85rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 0.2rem;
}
.session-card.active .s-title { color: #fff; font-weight: 600; }
.session-card .s-meta {
    font-size: 0.72rem;
    color: #64748b;
    display: flex;
    align-items: center;
    gap: 0.4rem;
}
.session-card.active .s-meta { color: #93c5fd; }

.sessions-empty {
    text-align: center;
    padding: 2rem 1rem;
    color: #475569;
    font-size: 0.8rem;
}

/* ── Main Chat Area ───────────────────────────── */
.chat-main {
    background: #f8fafc;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.chat-top-bar {
    padding: 0.85rem 1.25rem;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
}
.chat-top-bar-info { display: flex; flex-direction: column; gap: 0.15rem; }
.chat-top-bar-title { font-weight: 700; font-size: 0.95rem; color: var(--text); }
.chat-top-bar-meta { font-size: 0.75rem; color: var(--text-muted); display: flex; gap: 0.75rem; }
.chat-top-bar-badge {
    display: inline-flex; align-items: center; gap: 0.3rem;
    padding: 0.2rem 0.6rem;
    background: var(--accent-light);
    color: var(--accent);
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
}
.chat-top-bar-badge i { font-size: 0.7rem; }

/* ── Messages Area ────────────────────────────── */
.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
}
.chat-messages::-webkit-scrollbar { width: 5px; }
.chat-messages::-webkit-scrollbar-track { background: transparent; }
.chat-messages::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 999px; }

/* Message rows */
.msg-row {
    display: flex;
    gap: 0.6rem;
    animation: msgSlideIn 0.2s ease-out;
}
@@keyframes msgSlideIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
}
.msg-row.user { flex-direction: row-reverse; }

.msg-avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem;
    flex-shrink: 0;
    margin-top: 2px;
}
.msg-row.user .msg-avatar { background: var(--accent); color: #fff; }
.msg-row.assistant .msg-avatar { background: linear-gradient(135deg, #7c3aed, #4f46e5); color: #fff; }

.msg-body { max-width: 72%; display: flex; flex-direction: column; gap: 0.35rem; }
.msg-row.user .msg-body { align-items: flex-end; }

.msg-bubble {
    padding: 0.7rem 1rem;
    border-radius: 14px;
    font-size: 0.9rem;
    line-height: 1.6;
    word-break: break-word;
}
.msg-row.user .msg-bubble {
    background: var(--accent);
    color: #fff;
    border-bottom-right-radius: 4px;
    box-shadow: 0 2px 8px rgba(30,136,229,0.25);
}
.msg-row.assistant .msg-bubble {
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
    border-bottom-left-radius: 4px;
    box-shadow: var(--shadow);
}
.msg-row.assistant .msg-bubble.is-error {
    background: #fef2f2;
    border-color: #fca5a5;
    color: #991b1b;
}

/* Markdown-like rendering */
.msg-bubble p { margin-bottom: 0.5rem; }
.msg-bubble p:last-child { margin-bottom: 0; }
.msg-bubble strong { font-weight: 700; }
.msg-bubble em { font-style: italic; }
.msg-bubble code {
    font-family: 'Courier New', monospace;
    font-size: 0.82rem;
    background: rgba(0,0,0,0.06);
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
}
.msg-row.user .msg-bubble code { background: rgba(255,255,255,0.2); }
.msg-bubble ul, .msg-bubble ol {
    margin: 0.4rem 0 0.4rem 1.2rem;
}
.msg-bubble li { margin-bottom: 0.2rem; }

.msg-meta {
    font-size: 0.7rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.2rem;
}
.msg-latency {
    display: inline-flex; align-items: center; gap: 0.25rem;
    padding: 0.1rem 0.4rem;
    background: #f1f5f9;
    border-radius: 999px;
    font-size: 0.67rem;
    color: #64748b;
    font-weight: 500;
}

/* ── Citations Panel ──────────────────────────── */
.citations-panel {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.15rem;
}
.citation-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.6rem;
    background: linear-gradient(135deg, #eff6ff, #e0e7ff);
    border: 1px solid #bfdbfe;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    color: #1e40af;
    cursor: default;
    transition: all 0.15s;
    max-width: 220px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    position: relative;
}
.citation-pill:hover {
    background: linear-gradient(135deg, #dbeafe, #c7d2fe);
    border-color: #93c5fd;
    transform: translateY(-1px);
    box-shadow: 0 2px 6px rgba(59,130,246,0.2);
    max-width: none;
    overflow: visible;
    white-space: normal;
    z-index: 10;
}
.citation-pill .c-rank {
    width: 16px; height: 16px;
    background: #1e40af;
    color: #fff;
    border-radius: 50%;
    font-size: 0.6rem;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.citation-pill .c-score {
    margin-left: auto;
    background: rgba(30,64,175,0.12);
    border-radius: 999px;
    padding: 0 0.3rem;
    flex-shrink: 0;
}

/* ── Typing Indicator ─────────────────────────── */
.typing-row {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
}
.typing-bubble {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    border-bottom-left-radius: 4px;
    padding: 0.75rem 1rem;
    display: flex;
    gap: 4px;
    align-items: center;
    box-shadow: var(--shadow);
}
.typing-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #94a3b8;
    animation: typingBounce 1.2s infinite;
}
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@@keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
    30% { transform: translateY(-5px); opacity: 1; }
}

/* ── Input Area ───────────────────────────────── */
.chat-input-wrap {
    padding: 0.85rem 1.25rem 1rem;
    background: var(--surface);
    border-top: 1px solid var(--border);
    flex-shrink: 0;
}
.chat-input-box {
    display: flex;
    align-items: flex-end;
    gap: 0.6rem;
    background: #f8fafc;
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 0.5rem 0.5rem 0.5rem 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
}
.chat-input-box:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(30,136,229,0.12);
    background: #fff;
}
.chat-textarea {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 0.9rem;
    font-family: inherit;
    color: var(--text);
    resize: none;
    outline: none;
    min-height: 22px;
    max-height: 120px;
    line-height: 1.5;
    padding: 0;
}
.chat-textarea::placeholder { color: #94a3b8; }
.btn-send-msg {
    width: 38px; height: 38px;
    border-radius: 10px;
    background: var(--accent);
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    transition: background 0.15s, transform 0.1s;
    flex-shrink: 0;
}
.btn-send-msg:hover:not(:disabled) { background: var(--accent-hover); transform: scale(1.05); }
.btn-send-msg:disabled { background: #94a3b8; cursor: not-allowed; transform: none; }
.chat-hint {
    font-size: 0.7rem;
    color: #94a3b8;
    text-align: center;
    margin-top: 0.4rem;
}

/* ── Empty state ──────────────────────────────── */
.chat-empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem;
    text-align: center;
}
.chat-empty-icon {
    width: 72px; height: 72px;
    border-radius: 20px;
    background: linear-gradient(135deg, #eff6ff, #e0e7ff);
    border: 1px solid #bfdbfe;
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem;
}
.chat-empty-state h3 { font-size: 1.1rem; font-weight: 700; color: var(--text); }
.chat-empty-state p { font-size: 0.85rem; color: var(--text-muted); max-width: 320px; }

/* ── Modal ────────────────────────────────────── */
.modal-backdrop {
    position: fixed; inset: 0;
    background: rgba(15,23,42,0.5);
    backdrop-filter: blur(3px);
    z-index: 200;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
}
.modal-backdrop.open { display: flex; }
.modal-card {
    background: var(--surface);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: 0 20px 60px rgba(15,23,42,0.2);
    padding: 1.75rem;
    width: 100%;
    max-width: 480px;
    animation: modalIn 0.2s ease-out;
}
@@keyframes modalIn {
    from { opacity: 0; transform: scale(0.96) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
}
.modal-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1.25rem;
}
.modal-header h3 { font-size: 1.05rem; font-weight: 700; }
.modal-close {
    width: 28px; height: 28px;
    border-radius: 6px; border: none;
    background: #f1f5f9;
    color: var(--text-muted);
    cursor: pointer; font-size: 1rem;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s;
}
.modal-close:hover { background: #e2e8f0; color: var(--text); }
.modal-footer {
    display: flex; gap: 0.5rem; justify-content: flex-end;
    margin-top: 1.5rem;
}

/* Delete button in session card */
.session-delete-btn {
    display: none;
    width: 22px; height: 22px;
    border-radius: 4px; border: none;
    background: rgba(239,68,68,0.15);
    color: #fca5a5;
    cursor: pointer; font-size: 0.75rem;
    align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background 0.15s;
}
.session-card:hover .session-delete-btn { display: flex; }
.session-delete-btn:hover { background: rgba(239,68,68,0.35); color: #fecaca; }
</style>

@* Hidden antiforgery token for AJAX *@
@Html.AntiForgeryToken()

<div class="chat-page-wrapper">

    <!-- ── Sidebar ─────────────────────────────── -->
    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <h3><i class="bi bi-chat-dots-fill" style="margin-right:0.4rem;color:var(--accent);"></i>Lịch sử chat</h3>
            <button class="btn-new-chat" onclick="openModal()" title="Tạo chat mới">
                <i class="bi bi-plus-lg"></i>
            </button>
        </div>

        <div class="sessions-list">
            @foreach (var session in Model.Sessions)
            {
                <div class="session-card @(session.ChatSessionId == Model.CurrentSessionId ? "active" : "")"
                     onclick="window.location='/Chat/@session.ChatSessionId'">
                    <div style="display:flex; align-items:flex-start; gap:0.4rem;">
                        <div style="flex:1; min-width:0;">
                            <div class="s-title">@session.SessionTitle</div>
                            <div class="s-meta">
                                <i class="bi bi-book"></i>
                                @session.SubjectName
                                <span>·</span>
                                <i class="bi bi-chat"></i>
                                @session.MessageCount
                            </div>
                        </div>
                        <form method="post" asp-page-handler="DeleteSession" style="margin:0;"
                              onsubmit="return confirm('Xoá cuộc trò chuyện này?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="sessionId" value="@session.ChatSessionId" />
                            <button type="submit" class="session-delete-btn" title="Xoá">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    </div>
                </div>
            }
            @if (!Model.Sessions.Any())
            {
                <div class="sessions-empty">
                    <i class="bi bi-chat-square-dots" style="font-size:1.5rem; display:block; margin-bottom:0.5rem;"></i>
                    Chưa có cuộc trò chuyện nào
                </div>
            }
        </div>
    </div>

    <!-- ── Main Chat Area ──────────────────────── -->
    <div class="chat-main">
        @if (Model.CurrentSession != null)
        {
            <!-- Top bar -->
            <div class="chat-top-bar">
                <div class="chat-top-bar-info">
                    <div class="chat-top-bar-title">@Model.CurrentSession.SessionTitle</div>
                    <div class="chat-top-bar-meta">
                        <span><i class="bi bi-book"></i> @Model.CurrentSession.SubjectName</span>
                        <span><i class="bi bi-cpu"></i> @Model.CurrentSession.AiModelName</span>
                    </div>
                </div>
                <div style="display:flex; gap:0.5rem; align-items:center;">
                    <span class="chat-top-bar-badge">
                        <i class="bi bi-lightning-fill"></i> RAG Active
                    </span>
                </div>
            </div>

            <!-- Messages -->
            <div class="chat-messages" id="chat-messages">
                @foreach (var msg in Model.Messages)
                {
                    var fmtContent = string.IsNullOrWhiteSpace(msg.Content) ? "" :
                        System.Text.RegularExpressions.Regex.Replace(
                            System.Text.RegularExpressions.Regex.Replace(
                                System.Text.RegularExpressions.Regex.Replace(
                                    System.Net.WebUtility.HtmlEncode(msg.Content)
                                        .Replace("\n", "<br>"),
                                    @"\*\*(.+?)\*\*", "<strong>$1</strong>"),
                                @"\*(.+?)\*", "<em>$1</em>"),
                            "`(.+?)`", "<code>$1</code>");
                    <div class="msg-row @msg.Role">
                        <div class="msg-avatar">
                            @if (msg.Role == "user") { <i class="bi bi-person-fill"></i> }
                            else { <i class="bi bi-stars"></i> }
                        </div>
                        <div class="msg-body">
                            <div class="msg-bubble">
                                @Html.Raw(fmtContent)
                            </div>
                            <div class="msg-meta">
                                <span>@msg.CreatedAt.ToString("HH:mm")</span>
                                @if (msg.LatencyMs.HasValue)
                                {
                                    <span class="msg-latency">
                                        <i class="bi bi-speedometer2"></i>
                                        @msg.LatencyMs ms
                                    </span>
                                }
                                @if (msg.TokenCount.HasValue && msg.TokenCount.Value > 0)
                                {
                                    <span class="msg-latency">
                                        <i class="bi bi-coin"></i>
                                        @msg.TokenCount.Value.ToString("N0") token
                                    </span>
                                }
                            </div>
                            @if (msg.Citations.Any())
                            {
                                <div class="citations-panel">
                                    @foreach (var cite in msg.Citations)
                                    {
                                        <div class="citation-pill" title="@cite.ChunkText[..Math.Min(300, cite.ChunkText.Length)]...">
                                            <span class="c-rank">@cite.RetrievalRank</span>
                                            <span style="overflow:hidden; text-overflow:ellipsis;">
                                                <i class="bi bi-file-earmark-text"></i>
                                                @(cite.DocumentName?.Length > 30 ? cite.DocumentName[..28] + "…" : cite.DocumentName)
                                            </span>
                                            <span class="c-score">@cite.SimilarityScore.ToString("P0")</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Typing indicator (hidden) -->
                <div class="typing-row" id="typing-indicator" style="display:none;">
                    <div class="msg-avatar" style="background:linear-gradient(135deg,#7c3aed,#4f46e5);color:#fff;">
                        <i class="bi bi-stars"></i>
                    </div>
                    <div class="typing-bubble">
                        <div class="typing-dot"></div>
                        <div class="typing-dot"></div>
                        <div class="typing-dot"></div>
                    </div>
                </div>
            </div>

            <!-- Input -->
            <div class="chat-input-wrap">
                <div class="chat-input-box">
                    <textarea id="chat-textarea" class="chat-textarea" rows="1"
                              placeholder="Hỏi về nội dung môn học... (Enter để gửi, Shift+Enter xuống dòng)"></textarea>
                    <button id="btn-send" class="btn-send-msg" onclick="sendMessage()" title="Gửi (Enter)">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
                <div class="chat-hint">
                    <i class="bi bi-info-circle"></i>
                    AI chỉ trả lời dựa trên tài liệu đã upload. Nguồn trích dẫn hiển thị bên dưới mỗi câu trả lời.
                </div>
            </div>
        }
        else
        {
            <div class="chat-empty-state">
                <div class="chat-empty-icon">🤖</div>
                <h3>Chào mừng đến với Chat RAG</h3>
                <p>Đặt câu hỏi về bất kỳ nội dung học tập nào. AI sẽ tìm kiếm trong tài liệu và trả lời chính xác kèm trích dẫn nguồn.</p>
                <button class="btn btn-primary" onclick="openModal()">
                    <i class="bi bi-plus-lg"></i> Tạo cuộc trò chuyện mới
                </button>
            </div>
        }
    </div>
</div>

<!-- ── New Session Modal ────────────────────── -->
<div class="modal-backdrop" id="modal-backdrop" onclick="closeModalOnBackdrop(event)">
    <div class="modal-card">
        <div class="modal-header">
            <h3><i class="bi bi-plus-circle" style="color:var(--accent); margin-right:0.4rem;"></i>Tạo cuộc trò chuyện mới</h3>
            <button class="modal-close" onclick="closeModal()"><i class="bi bi-x-lg"></i></button>
        </div>
        <form method="post" asp-page-handler="CreateSession">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Tiêu đề cuộc trò chuyện</label>
                <input type="text" name="SessionTitle" class="form-control" value="Chat mới" required
                       placeholder="Nhập tiêu đề..." />
            </div>
            <div class="form-group">
                <label class="form-label">Môn học</label>
                <select name="SubjectId" class="form-control" required>
                    <option value="">-- Chọn môn học --</option>
                    @foreach (var s in Model.AvailableSubjects)
                    {
                        <option value="@s.SubjectId">@s.SubjectCode — @s.SubjectName</option>
                    }
                </select>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
                <div class="form-group">
                    <label class="form-label">AI Model</label>
                    <select name="AiModelId" class="form-control" required>
                        @foreach (var m in Model.AvailableAiModels)
                        {
                            <option value="@m.AiModelId">@m.ModelName</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Embedding Model</label>
                    <select name="EmbeddingModelId" class="form-control" required>
                        @foreach (var m in Model.AvailableEmbeddingModels)
                        {
                            <option value="@m.EmbeddingModelId">@m.ModelName</option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal()">Huỷ</button>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Tạo chat
                </button>
            </div>
        </form>
    </div>
</div>



@section Scripts {
<script>
const sessionId = @(Model.CurrentSessionId?.ToString() ?? "null");
const msgsEl = document.getElementById('chat-messages');
const textarea = document.getElementById('chat-textarea');
const btnSend = document.getElementById('btn-send');
const typingIndicator = document.getElementById('typing-indicator');

// Auto-scroll on load
if (msgsEl) msgsEl.scrollTop = msgsEl.scrollHeight;

// Textarea auto-resize + Enter to send
if (textarea) {
    textarea.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });
    textarea.addEventListener('input', function () {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });
}

async function sendMessage() {
    if (!sessionId || !textarea) return;
    const question = textarea.value.trim();
    if (!question) return;

    textarea.value = '';
    textarea.style.height = 'auto';
    btnSend.disabled = true;

    appendMessage('user', question);
    showTyping(true);

    try {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        const resp = await fetch('/Chat?handler=SendMessage', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify({ chatSessionId: sessionId, question })
        });

        const data = await resp.json();
        showTyping(false);

        if (data.isError) {
            appendMessage('assistant', data.errorMessage, [], true);
        } else {
            appendMessage('assistant', data.answer, data.citations || [], false, data.latencyMs, data.tokensUsedThisMessage, data.userTokensUsed);
        }
    } catch (err) {
        showTyping(false);
        appendMessage('assistant', '⚠️ Lỗi kết nối. Vui lòng thử lại.', [], true);
    }

    btnSend.disabled = false;
    scrollToBottom();
}

function showTyping(show) {
    if (typingIndicator) {
        typingIndicator.style.display = show ? 'flex' : 'none';
        if (show) scrollToBottom();
    }
}

function scrollToBottom() {
    if (msgsEl) msgsEl.scrollTop = msgsEl.scrollHeight;
}

function formatContent(text) {
    if (!text) return '';
    let html = text
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
        .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
        .replace(/\*(.+?)\*/g,'<em>$1</em>')
        .replace(/`(.+?)`/g,'<code>$1</code>')
        .replace(/\n/g,'<br>');
    return html;
}

function appendMessage(role, content, citations = [], isError = false, latencyMs = null, tokensThisMsg = null, userTokensTotal = null) {
    const row = document.createElement('div');
    row.className = 'msg-row ' + role;

    const avatarIcon = role === 'user' ? 'bi-person-fill' : 'bi-stars';
    const avatarStyle = role === 'user'
        ? 'background:var(--accent);color:#fff;'
        : 'background:linear-gradient(135deg,#7c3aed,#4f46e5);color:#fff;';

    const bubbleClass = isError ? 'msg-bubble is-error' : 'msg-bubble';
    const timeStr = new Date().toLocaleTimeString('vi', { hour: '2-digit', minute: '2-digit' });
    const latencyHtml = latencyMs
        ? `<span class="msg-latency"><i class="bi bi-speedometer2"></i> ${latencyMs} ms</span>`
        : '';
    const tokenHtml = (tokensThisMsg != null && tokensThisMsg > 0)
        ? `<span class="msg-latency"><i class="bi bi-coin"></i> ${tokensThisMsg.toLocaleString('vi')} token` +
          (userTokensTotal != null ? ` · tổng ${userTokensTotal.toLocaleString('vi')}` : '') +
          `</span>`
        : '';

    // Build citations HTML
    let citHtml = '';
    if (citations && citations.length > 0) {
        citHtml = '<div class="citations-panel">' +
            citations.map((c, i) => {
                const name = (c.documentName || 'Tài liệu');
                const displayName = name.length > 30 ? name.slice(0,28) + '…' : name;
                const score = c.similarityScore ? (c.similarityScore * 100).toFixed(0) + '%' : '';
                const snippet = (c.chunkText || '').slice(0, 300).replace(/</g,'&lt;').replace(/>/g,'&gt;');
                return `<div class="citation-pill" title="${snippet}...">
                    <span class="c-rank">${i+1}</span>
                    <span style="overflow:hidden;text-overflow:ellipsis;">
                        <i class="bi bi-file-earmark-text"></i> ${displayName}
                    </span>
                    ${score ? `<span class="c-score">${score}</span>` : ''}
                </div>`;
            }).join('') +
        '</div>';
    }

    row.innerHTML = `
        <div class="msg-avatar" style="${avatarStyle}"><i class="bi ${avatarIcon}"></i></div>
        <div class="msg-body">
            <div class="${bubbleClass}">${formatContent(content)}</div>
            <div class="msg-meta">
                <span>${timeStr}</span>
                ${latencyHtml}
                ${tokenHtml}
            </div>
            ${citHtml}
        </div>
    `;

    if (typingIndicator) {
        msgsEl.insertBefore(row, typingIndicator);
    } else {
        msgsEl.appendChild(row);
    }
    scrollToBottom();
}

// ── Modal control ─────────────────────────────────────────
const modalBackdrop = document.getElementById('modal-backdrop');
function openModal() { modalBackdrop.classList.add('open'); }
function closeModal() { modalBackdrop.classList.remove('open'); }
function closeModalOnBackdrop(e) { if (e.target === modalBackdrop) closeModal(); }
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
}
