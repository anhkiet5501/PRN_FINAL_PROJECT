@page
@model PRN222_Assignment2.Pages.Auth.ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EduManager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .login-topbar {
            background: #1a2332;
            color: #fff;
            padding: 1rem 1.5rem;
            font-weight: 700;
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 10;
        }
        .login-page { padding-top: 4rem; }
    </style>
</head>
<body>
    <div class="login-topbar">EduManager Web App</div>
    <div class="login-page">
        <div class="login-card">
            <div class="login-brand">
                <div class="login-brand-icon"><i class="bi bi-shield-lock"></i></div>
                <h1>Đặt lại mật khẩu</h1>
                <p>Nhập mã xác nhận từ email và mật khẩu mới</p>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-error">@Model.ErrorMessage</div>
            }

            <form method="post">
                @Html.AntiForgeryToken()
                
                <div class="login-form-group">
                    <label for="Email"><i class="bi bi-envelope"></i> Email của bạn</label>
                    <input type="email" id="Email" name="Email" class="login-input" value="@Model.Email" readonly style="background: #f3f4f6; color: #6b7280;" />
                </div>
                
                <div class="login-form-group">
                    <label for="Code"><i class="bi bi-123"></i> Mã xác nhận (6 số)</label>
                    <input type="text" id="Code" name="Code" class="login-input" placeholder="Ví dụ: 123456" required autocomplete="off" />
                </div>

                <div class="login-form-group">
                    <label for="NewPassword"><i class="bi bi-lock"></i> Mật khẩu mới</label>
                    <input type="password" id="NewPassword" name="NewPassword" class="login-input" placeholder="Nhập mật khẩu mới" required />
                </div>

                <div class="login-form-group">
                    <label for="ConfirmPassword"><i class="bi bi-lock-fill"></i> Xác nhận mật khẩu mới</label>
                    <input type="password" id="ConfirmPassword" name="ConfirmPassword" class="login-input" placeholder="Nhập lại mật khẩu mới" required />
                </div>

                <button type="submit" class="btn-login" id="btn-submit">
                    <i class="bi bi-check2-circle"></i> Đổi mật khẩu
                </button>
            </form>
            
            <div style="margin-top: 1.5rem; text-align: center;">
                <a href="/Auth/ForgotPassword" style="color: #6b7280; font-size: 0.875rem; text-decoration: none;"><i class="bi bi-arrow-left"></i> Gửi lại mã khác</a>
            </div>
        </div>
    </div>
</body>
</html>
