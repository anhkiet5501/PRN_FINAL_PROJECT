@page
@model PRN222_Assignment2.Pages.Auth.ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EduManager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .login-topbar {
            background: #1a2332;
            color: #fff;
            padding: 1rem 1.5rem;
            font-weight: 700;
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 10;
        }
        .login-page { padding-top: 4rem; }
    </style>
</head>
<body>
    <div class="login-topbar">EduManager Web App</div>
    <div class="login-page">
        <div class="login-card">
            <div class="login-brand">
                <div class="login-brand-icon"><i class="bi bi-key"></i></div>
                <h1>Quên mật khẩu</h1>
                <p>Nhập email để nhận mã khôi phục</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-error">@Model.ErrorMessage</div>
            }

            <form method="post">
                @Html.AntiForgeryToken()
                <div class="login-form-group">
                    <label for="Email"><i class="bi bi-envelope"></i> Email của bạn</label>
                    <input type="email" id="Email" name="Email" class="login-input" value="@Model.Email" placeholder="example@gmail.com" required />
                </div>
                <button type="submit" class="btn-login" id="btn-submit">
                    <i class="bi bi-send"></i> Nhận mã xác nhận
                </button>
            </form>
            <div style="margin-top: 1.5rem; text-align: center;">
                <a href="/Auth/Login" style="color: #6b7280; font-size: 0.875rem; text-decoration: none;"><i class="bi bi-arrow-left"></i> Quay lại đăng nhập</a>
            </div>
        </div>
    </div>
</body>
</html>
