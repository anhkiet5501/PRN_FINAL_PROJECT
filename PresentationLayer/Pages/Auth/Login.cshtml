@page
@model PRN222_Assignment2.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EduManager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .login-topbar {
            background: #1a2332;
            color: #fff;
            padding: 1rem 1.5rem;
            font-weight: 700;
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 10;
        }
        .login-page { padding-top: 4rem; }
    </style>
</head>
<body>
    <div class="login-topbar">EduManager Web App</div>
    <div class="login-page">
        <div class="login-card">
            <div class="login-brand">
                <div class="login-brand-icon"><i class="bi bi-mortarboard-fill"></i></div>
                <h1>EduManager</h1>
                <p>Hệ thống quản lý học tập</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-error">@Model.ErrorMessage</div>
            }

            <form method="post" id="login-form">
                @Html.AntiForgeryToken()
                <div class="login-form-group">
                    <label for="Username"><i class="bi bi-person"></i> Tên đăng nhập</label>
                    <input type="text" id="Username" name="Input.Username"
                           class="login-input"
                           value="@Model.Input.Username"
                           placeholder="admin" autocomplete="username" required />
                </div>
                <div class="login-form-group">
                    <label for="Password"><i class="bi bi-lock"></i> Mật khẩu</label>
                    <input type="password" id="Password" name="Input.Password"
                           class="login-input"
                           placeholder="••••••••" autocomplete="current-password" required />
                </div>
                <div class="remember-row">
                    <input type="checkbox" id="RememberMe" name="Input.RememberMe" value="true" />
                    <label for="RememberMe">Ghi nhớ đăng nhập</label>
                </div>
                <button type="submit" class="btn-login" id="btn-submit">
                    <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                </button>
            </form>
        </div>
    </div>

    <script>
        document.getElementById('login-form').addEventListener('submit', function() {
            var btn = document.getElementById('btn-submit');
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang xử lý...';
            btn.disabled = true;
        });
    </script>
</body>
</html>
