@page
@model PRN222_Assignment2.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Tài liệu";
    ViewData["ActivePage"] = "Documents";
}

<div class="page-header-row">
    <div>
        <h1 class="dashboard-title" style="margin-bottom:0.25rem;">LỊCH SỬ TÀI LIỆU ĐÃ TẢI LÊN</h1>
        <p class="page-subtitle" style="margin-bottom:0;">Danh sách tất cả các tài liệu do bạn đăng tải. Lịch sử này được giữ nguyên ngay cả khi môn học được chuyển cho giảng viên khác phụ trách.</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="alert alert-info" style="margin-bottom:0; padding:0.35rem 0.75rem;">
            <span style="font-size:0.8rem;">Admin chỉ có quyền xem tài liệu và Re-Index.</span>
        </div>
    }
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null)
{ <div class="alert alert-error">@TempData["Error"]</div> }

<div class="card filter-bar">
    <form method="get" class="filter-form">
        <select name="subjectId" class="form-control" style="width:250px;" onchange="this.form.submit()">
            <option value="">-- Tất cả môn học --</option>
            @foreach (var s in Model.Subjects)
            {
                <option value="@s.SubjectId" selected="@(Model.SelectedSubjectId == s.SubjectId)">
                    @s.SubjectCode — @s.SubjectName
                </option>
            }
        </select>
        <select name="status" class="form-control" style="width:200px;" onchange="this.form.submit()">
            <option value="">-- Tất cả trạng thái --</option>
            <option value="Pending" selected="@(Model.SelectedStatus == "Pending")">Pending</option>
            <option value="Processing" selected="@(Model.SelectedStatus == "Processing")">Processing</option>
            <option value="Indexed" selected="@(Model.SelectedStatus == "Indexed")">Indexed</option>
            <option value="Failed" selected="@(Model.SelectedStatus == "Failed")">Failed</option>
        </select>
    </form>
</div>

<div class="brutalist-table-container">
    <table class="brutalist-table">
        <thead>
            <tr>
                <th>Tên tài liệu</th>
                <th>Môn học</th>
                <th>Chương</th>
                <th>Người đăng</th>
                <th>Ngày đăng</th>
                <th style="text-align:center;">Loại</th>
                <th style="text-align:center;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in Model.Documents)
            {
                <tr>
                    <td style="font-weight:700;">@doc.OriginalFileName</td>
                    <td>@doc.SubjectName</td>
                    <td>@doc.ChapterName</td>
                    <td class="text-link">@doc.UploadedByFullName</td>
                    <td>
                        <div style="font-weight:600;">@doc.UploadedAt.ToString("dd/MM/yyyy")</div>
                        <div style="font-size:0.8rem; color:var(--color-gray);">@doc.UploadedAt.ToString("HH:mm")</div>
                    </td>
                    <td style="text-align:center;">
                        <span class="doc-badge">@doc.FileType?.ToUpper()</span>
                    </td>
                    <td style="text-align:center;">
                        <a href="/Documents/View/@doc.DocumentId" class="btn-action btn-action-edit"><i class="bi bi-eye"></i> Xem</a>
                    </td>
                </tr>
            }
            @if (!Model.Documents.Any())
            {
                <tr>
                    <td colspan="7" class="empty-state">
                        <div style="font-size:2rem; margin-bottom:0.5rem;"><i class="bi bi-file-earmark"></i></div>
                        Không có tài liệu nào.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
let reloadScheduled = false;
function scheduleReload() {
    if (reloadScheduled) return;
    reloadScheduled = true;
    setTimeout(() => location.reload(), 400);
}

const documentConnection = new signalR.HubConnectionBuilder()
    .withUrl("/documentHub")
    .build();

documentConnection.on("ReceiveDocumentUpdate", function (action, payload) {
    console.log("Document SignalR:", action, payload);
    scheduleReload();
});

documentConnection.start().catch(function (err) {
    console.error("Document SignalR Error:", err.toString());
});
</script>
}

@functions {
    string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return bytes + " B";
        if (bytes < 1048576) return (bytes / 1024.0).ToString("F1") + " KB";
        return (bytes / 1048576.0).ToString("F1") + " MB";
    }
}
