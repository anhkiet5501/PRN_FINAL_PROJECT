@page "{id:int}"
@model PRN222_Assignment2.Pages.Documents.DetailsModel
@{
    ViewData["Title"] = "Chi tiết chunks";
    var fileType = (Model.Document?.FileType ?? "").Trim().TrimStart('.').ToLowerInvariant();
}

<div class="page-header-row" style="margin-bottom: 1.5rem;">
    <div>
        <h1 class="dashboard-title">@(string.IsNullOrEmpty(Model.Document?.OriginalFileName) ? "Tài liệu" : System.IO.Path.GetFileNameWithoutExtension(Model.Document.OriginalFileName))</h1>
        <p class="page-subtitle" style="margin-bottom:0;">
            Loại file: <strong>@(fileType.ToUpper())</strong> &bull; 
            Cập nhật: @(Model.Document?.IndexedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? Model.Document?.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "N/A") &bull; 
            Người tải: @(Model.Document?.UploadedByFullName ?? "lecturer")
            @if (Model.Chunks.Any())
            {
                <span class="badge" style="background-color: var(--accent-light); color: var(--accent); margin-left: 0.5rem;">
                    <i class="bi bi-diagram-3"></i> @Model.Chunks.Count chunks
                </span>
            }
        </p>
    </div>
    <div style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items: center;">
        <a href="javascript:history.back()" class="soft-btn btn-light">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

@if (Model.Document == null)
{
    <div class="alert alert-error">
        <i class="bi bi-exclamation-triangle-fill"></i> Không tìm thấy tài liệu.
    </div>
}
else
{
    <!-- Tab Navigation -->
    <div class="neo-tabs-container">
        <button class="neo-tab" id="btn-tab-content" onclick="switchTab('content')">
            NỘI DUNG
        </button>
        <button class="neo-tab" id="btn-tab-chunks" onclick="switchTab('chunks')">
            <i class="bi bi-diagram-3"></i> VECTOR CHUNKS (@Model.Chunks.Count)
        </button>
    </div>
    <div class="neo-tabs-line"></div>

    <!-- Tab Contents -->
    <div id="pane-tab-content" class="tab-pane" style="display: none;">
        <div class="card">
            <h3 class="card-title">
                <i class="bi bi-file-text"></i> Nội dung trích xuất
            </h3>
            <div class="doc-preview" style="white-space: pre-wrap; word-break: break-word; line-height: 1.7; font-size: 0.95rem; max-height: 60vh; overflow-y: auto;">
                @Model.PreviewText
            </div>
        </div>
    </div>

    <div id="pane-tab-chunks" class="tab-pane" style="display: none;">
        <!-- Status Alert Banner -->
        @if (Model.Document?.Status == "Indexed")
        {
            <div class="alert alert-success" style="display: flex; align-items: center; gap: 0.5rem;">
                <i class="bi bi-check-circle-fill" style="font-size: 1.2rem;"></i> Băm và Nhúng Vector thành công!
            </div>
        }
        else if (Model.Document?.Status == "Failed")
        {
            <div class="alert alert-error" style="display: flex; align-items: center; gap: 0.5rem;">
                <i class="bi bi-exclamation-triangle-fill" style="font-size: 1.2rem;"></i> Băm và Nhúng Vector thất bại! Lỗi: @Model.Document.ErrorMessage
            </div>
        }
        else
        {
            <div class="alert alert-warning" style="display: flex; align-items: center; gap: 0.5rem;">
                <i class="bi bi-hourglass-split" style="font-size: 1.2rem;"></i> Đang xử lý băm & nhúng vector...
            </div>
        }

        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; flex-wrap:wrap; gap:0.5rem;">
            <h3 style="font-size:1.1rem; font-weight:bold; margin:0; font-style:italic; color:#333;">
                Các đoạn văn bản (Chunks) đã Vector Embedding bằng Gemini AI.
            </h3>
            @if (Model.Document?.Status == "Indexed")
            {
                <span class="doc-status doc-status--indexed"><i class="bi bi-check-lg"></i> ĐÃ VECTOR HÓA</span>
            }
            else if (Model.Document?.Status == "Failed")
            {
                <span class="doc-status doc-status--failed"><i class="bi bi-x-lg"></i> LỖI VECTOR</span>
            }
            else
            {
                <span class="doc-status doc-status--processing"><i class="bi bi-hourglass-split"></i> ĐANG XỬ LÝ</span>
            }
        </div>

        @if (Model.Chunks.Any())
        {
            <div class="chunk-list">
                @foreach (var chunk in Model.Chunks)
                {
                    <div class="chunk-item">
                        <div class="chunk-item-header">
                            CHUNK #@chunk.ChunkIndex | @chunk.TokenCount từ
                        </div>
                        <div class="chunk-item-body">@chunk.ChunkText</div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card" style="text-align:center; padding:3rem; border: 1px dashed var(--border); background:#fff;">
                <p style="color:var(--text-muted); font-size:1.1rem; margin-bottom:1rem;">Chưa có dữ liệu chunk nào được tạo cho tài liệu này.</p>
                <a href="javascript:history.back()" class="soft-btn btn-light">
                    <i class="bi bi-arrow-left"></i> Quay lại trang môn học
                </a>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        function switchTab(tabId) {
            // Hide all tab panes
            document.querySelectorAll('.tab-pane').forEach(function(pane) {
                pane.style.display = 'none';
            });
            
            // Remove active class from all tabs
            document.querySelectorAll('.neo-tab').forEach(function(tab) {
                tab.classList.remove('active');
            });
            
            // Show selected tab pane
            var activePane = document.getElementById('pane-tab-' + tabId);
            if (activePane) {
                activePane.style.display = 'block';
            }
            
            // Add active class to selected tab button
            var activeTabBtn = document.getElementById('btn-tab-' + tabId);
            if (activeTabBtn) {
                activeTabBtn.classList.add('active');
            }
        }
        
        // Default: If chunks exist, active tab is chunks, else content
        document.addEventListener("DOMContentLoaded", function() {
            var urlParams = new URLSearchParams(window.location.search);
            var tabParam = urlParams.get('tab');
            
            if (tabParam === 'content') {
                switchTab('content');
            } else if (tabParam === 'chunks') {
                switchTab('chunks');
            } else {
                var hasChunks = @(Model.Chunks.Any() ? "true" : "false");
                if (hasChunks) {
                    switchTab('chunks');
                } else {
                    switchTab('content');
                }
            }
        });
    </script>
}
