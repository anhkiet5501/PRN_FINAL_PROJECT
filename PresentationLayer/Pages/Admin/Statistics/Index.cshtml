@page
@model PRN222_Assignment2.Pages.Admin.Statistics.IndexModel
@{
    ViewData["Title"] = "Thống kê hệ thống";
    ViewData["ActivePage"] = "Statistics";
    var s = Model.Stats;
    var kb = s.KnowledgeBase;
    var ai = s.AiRag;
    var learn = s.Learning;
}

<style>
.stats-kpi-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.25rem;
}
.stats-kpi-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    box-shadow: var(--shadow);
    display: flex;
    align-items: center;
    gap: 0.85rem;
}
.stats-kpi-icon {
    width: 42px; height: 42px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.15rem;
    flex-shrink: 0;
}
.stats-kpi-icon.blue   { background: #eff6ff; color: #2563eb; }
.stats-kpi-icon.green  { background: #f0fdf4; color: #16a34a; }
.stats-kpi-icon.amber  { background: #fffbeb; color: #d97706; }
.stats-kpi-icon.purple { background: #faf5ff; color: #7c3aed; }
.stats-kpi-icon.red    { background: #fef2f2; color: #dc2626; }
.stats-kpi-icon.teal   { background: #f0fdfa; color: #0d9488; }
.stats-kpi-value { font-size: 1.55rem; font-weight: 800; color: var(--text); line-height: 1; }
.stats-kpi-label { font-size: 0.72rem; color: var(--text-muted); font-weight: 500; margin-top: 0.2rem; }

.stats-section-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 1.75rem 0 0.85rem;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.stats-section-title:first-of-type { margin-top: 0.5rem; }
.stats-section-title i { color: var(--accent); }

.stats-charts-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
}
.stats-chart-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow);
}
.stats-chart-title {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.stats-chart-title i { color: var(--accent); }
.stats-chart-wrap { position: relative; height: 240px; }

.stats-tables-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
}
.stats-table-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
}
.stats-table-card h3 {
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--border);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.stats-table { width: 100%; border-collapse: collapse; }
.stats-table th {
    padding: 0.65rem 1rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    color: var(--text-muted);
    background: #f8fafc;
    border-bottom: 1px solid var(--border);
    text-align: left;
}
.stats-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #f1f5f9;
    font-size: 0.875rem;
}
.stats-table tbody tr:hover { background: #f8fafc; }
.stats-empty {
    padding: 2rem 1rem;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
}
.stats-role-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    background: #f1f5f9;
    border: 1px solid var(--border);
}

.stats-filter-bar {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin-bottom: 1.25rem;
    box-shadow: var(--shadow);
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-end;
}
.stats-filter-presets {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    flex: 1;
}
.stats-period-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: #f8fafc;
    color: var(--text);
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.15s ease;
}
.stats-period-btn:hover { border-color: var(--accent); color: var(--accent); }
.stats-period-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
}
.stats-custom-range {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: flex-end;
}
.stats-custom-range label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-muted);
}
.stats-custom-range input[type="date"] {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.4rem 0.55rem;
    font-size: 0.85rem;
    background: #fff;
}
.stats-period-hint {
    width: 100%;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
}

@@media (max-width: 960px) {
    .stats-kpi-row { grid-template-columns: repeat(2, 1fr); }
    .stats-charts-row, .stats-tables-row { grid-template-columns: 1fr; }
}
@@media (max-width: 560px) {
    .stats-kpi-row { grid-template-columns: 1fr; }
}
</style>

<div class="page-header-row">
    <h1 class="dashboard-title" style="margin-bottom:0;">THỐNG KÊ HỆ THỐNG</h1>
    <a href="/Admin/Users" class="soft-btn btn-light"><i class="bi bi-people"></i> Quản lý người dùng</a>
</div>

@{
    string PeriodHref(string p) => $"/Admin/Statistics?period={p}";
    string ActivePeriod(string p) => Model.Period == p ? "active" : "";
    var fromVal = Model.From?.ToString("yyyy-MM-dd")
        ?? (s.FromUtc.HasValue ? s.FromUtc.Value.ToString("yyyy-MM-dd") : "");
    var toVal = Model.To?.ToString("yyyy-MM-dd")
        ?? (s.ToUtc.HasValue ? s.ToUtc.Value.AddDays(-1).ToString("yyyy-MM-dd") : DateTime.UtcNow.ToString("yyyy-MM-dd"));
}

<form method="get" class="stats-filter-bar" id="stats-filter-form">
    <div class="stats-filter-presets">
        <a class="stats-period-btn @ActivePeriod("today")" href="@PeriodHref("today")">Hôm nay</a>
        <a class="stats-period-btn @ActivePeriod("7d")" href="@PeriodHref("7d")">7 ngày</a>
        <a class="stats-period-btn @ActivePeriod("30d")" href="@PeriodHref("30d")">30 ngày</a>
        <a class="stats-period-btn @ActivePeriod("month")" href="@PeriodHref("month")">Tháng này</a>
        <a class="stats-period-btn @ActivePeriod("3m")" href="@PeriodHref("3m")">3 tháng</a>
        <a class="stats-period-btn @ActivePeriod("6m")" href="@PeriodHref("6m")">6 tháng</a>
        <a class="stats-period-btn @ActivePeriod("all")" href="@PeriodHref("all")">Toàn thời gian</a>
        <a class="stats-period-btn @ActivePeriod("custom")" href="#" onclick="document.getElementById('period-custom').value='custom'; return false;">Tùy chọn</a>
    </div>
    <div class="stats-custom-range">
        <input type="hidden" name="period" id="period-custom" value="@(Model.Period == "custom" ? "custom" : Model.Period)" />
        <label>
            Từ ngày
            <input type="date" name="from" value="@fromVal" />
        </label>
        <label>
            Đến ngày
            <input type="date" name="to" value="@toVal" />
        </label>
        <button type="submit" class="soft-btn btn-primary" onclick="document.getElementById('period-custom').value='custom';">
            <i class="bi bi-funnel"></i> Áp dụng
        </button>
    </div>
    <p class="stats-period-hint">
        <i class="bi bi-calendar3"></i>
        Đang xem: <strong>@s.PeriodLabel</strong>
        @if (s.FromUtc.HasValue)
        {
            <text> (@s.FromUtc.Value.ToLocalTime().ToString("dd/MM/yyyy") – @((s.ToUtc ?? DateTime.UtcNow).ToLocalTime().ToString("dd/MM/yyyy")))</text>
        }
    </p>
</form>

@* ── User overview ──────────────────────────────────────── *@
<h2 class="stats-section-title"><i class="bi bi-people"></i> Tổng quan người dùng</h2>
<div class="stats-kpi-row">
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon blue"><i class="bi bi-people-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@s.TotalUsers</div>
            <div class="stats-kpi-label">@(s.Period == "all" ? "Tổng người dùng" : "Người dùng mới trong kỳ")</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon green"><i class="bi bi-person-check-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@s.ActiveUsers</div>
            <div class="stats-kpi-label">Tài khoản đang hoạt động</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon amber"><i class="bi bi-person-plus-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@s.NewUsersThisMonth</div>
            <div class="stats-kpi-label">Đăng ký trong kỳ</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon teal"><i class="bi bi-link-45deg"></i></div>
        <div>
            <div class="stats-kpi-value">@s.TeachersWithAssignments</div>
            <div class="stats-kpi-label">GV đã được gán môn</div>
        </div>
    </div>
</div>

<div class="stats-charts-row">
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-pie-chart-fill"></i> Phân bố theo vai trò</div>
        <div class="stats-chart-wrap"><canvas id="roleChart"></canvas></div>
    </div>
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-graph-up"></i> Đăng ký mới theo tháng (@s.PeriodLabel)</div>
        <div class="stats-chart-wrap"><canvas id="regChart"></canvas></div>
    </div>
</div>

@* ── Knowledge Base ─────────────────────────────────────── *@
<h2 class="stats-section-title"><i class="bi bi-database"></i> Thống kê kho tri thức</h2>
<div class="stats-kpi-row">
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon blue"><i class="bi bi-file-earmark-text-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@kb.TotalDocuments</div>
            <div class="stats-kpi-label">Tài liệu</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon red"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@kb.ErrorRatePercent.ToString("0.#")%</div>
            <div class="stats-kpi-label">Tỷ lệ lỗi lập chỉ mục</div>
        </div>
    </div>
</div>
<div class="stats-kpi-row">
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon green"><i class="bi bi-check-circle-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@kb.IndexedDocuments</div>
            <div class="stats-kpi-label">Đã lập chỉ mục</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon amber"><i class="bi bi-hourglass-split"></i></div>
        <div>
            <div class="stats-kpi-value">@(kb.PendingDocuments + kb.ProcessingDocuments)</div>
            <div class="stats-kpi-label">Chờ xử lý / Đang xử lý</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon blue"><i class="bi bi-stopwatch"></i></div>
        <div>
            <div class="stats-kpi-value">@(kb.AvgIndexingSeconds?.ToString("0.##") ?? "—")</div>
            <div class="stats-kpi-label">Thời gian lập chỉ mục TB (giây)</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon purple"><i class="bi bi-speedometer2"></i></div>
        <div>
            <div class="stats-kpi-value">@(kb.P95IndexingSeconds?.ToString("0.##") ?? "—")</div>
            <div class="stats-kpi-label">Thời gian lập chỉ mục P95 (giây)</div>
        </div>
    </div>
</div>
<div class="stats-charts-row">
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-bar-chart-fill"></i> Trạng thái tài liệu</div>
        <div class="stats-chart-wrap"><canvas id="docStatusChart"></canvas></div>
    </div>
    <div class="stats-table-card">
        <h3><i class="bi bi-cloud-upload"></i> Người tải tài liệu nhiều nhất</h3>
        @if (s.TopUploaders.Any())
        {
            <table class="stats-table">
                <thead><tr><th>#</th><th>Người dùng</th><th>Số tài liệu</th></tr></thead>
                <tbody>
                    @{ var ui = 1; }
                    @foreach (var u in s.TopUploaders)
                    {
                        <tr>
                            <td>@ui</td>
                            <td style="font-weight:500;">@u.DisplayName</td>
                            <td><strong>@u.Count</strong></td>
                        </tr>
                        ui++;
                    }
                </tbody>
            </table>
        }
        else { <div class="stats-empty">Chưa có dữ liệu.</div> }
    </div>
</div>

@* ── AI & RAG ───────────────────────────────────────────── *@
<h2 class="stats-section-title"><i class="bi bi-robot"></i> Thống kê AI &amp; RAG</h2>
<div class="stats-kpi-row">
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon blue"><i class="bi bi-chat-dots-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@ai.TotalChatSessions</div>
            <div class="stats-kpi-label">Cuộc trò chuyện</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon purple"><i class="bi bi-chat-left-quote-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@ai.TotalQuestions</div>
            <div class="stats-kpi-label">Câu hỏi</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon teal"><i class="bi bi-coin"></i></div>
        <div>
            <div class="stats-kpi-value">@ai.TotalTokens.ToString("N0")</div>
            <div class="stats-kpi-label">Token đã dùng</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon amber"><i class="bi bi-lightning-charge-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@(ai.AvgLatencyMs?.ToString("0") ?? "—")</div>
            <div class="stats-kpi-label">Thời gian phản hồi TB (ms) · P95 @(ai.P95LatencyMs?.ToString("0") ?? "—")</div>
        </div>
    </div>
</div>
<div class="stats-charts-row">
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-pie-chart"></i> Truy vấn có / không ngữ cảnh (@ai.ContextHitRatePercent.ToString("0.#")% có ngữ cảnh)</div>
        <div class="stats-chart-wrap"><canvas id="contextChart"></canvas></div>
    </div>
    <div class="stats-table-card">
        <h3><i class="bi bi-coin"></i> Người dùng dùng nhiều token nhất</h3>
        @if (ai.TopTokenUsers.Any())
        {
            <table class="stats-table">
                <thead><tr><th>#</th><th>Người dùng</th><th>Token</th></tr></thead>
                <tbody>
                    @{ var ti = 1; }
                    @foreach (var u in ai.TopTokenUsers)
                    {
                        <tr>
                            <td>@ti</td>
                            <td style="font-weight:500;">@u.DisplayName</td>
                            <td><strong>@u.Count.ToString("N0")</strong></td>
                        </tr>
                        ti++;
                    }
                </tbody>
            </table>
        }
        else { <div class="stats-empty">Chưa có token được ghi nhận.</div> }
    </div>
</div>
<div class="stats-tables-row">
    <div class="stats-table-card">
        <h3><i class="bi bi-bookmark-star"></i> Chủ đề được hỏi nhiều nhất (theo môn)</h3>
        @if (ai.TopSubjectsAsked.Any())
        {
            <table class="stats-table">
                <thead><tr><th>#</th><th>Môn học</th><th>Phiên trò chuyện</th></tr></thead>
                <tbody>
                    @{ var si = 1; }
                    @foreach (var item in ai.TopSubjectsAsked)
                    {
                        <tr>
                            <td>@si</td>
                            <td style="font-weight:500;">@item.Name</td>
                            <td><strong>@item.Count</strong></td>
                        </tr>
                        si++;
                    }
                </tbody>
            </table>
        }
        else { <div class="stats-empty">Chưa có dữ liệu.</div> }
    </div>
    <div class="stats-table-card">
        <h3><i class="bi bi-file-earmark-richtext"></i> Tài liệu được truy xuất nhiều nhất</h3>
        @if (ai.TopRetrievedDocuments.Any())
        {
            <table class="stats-table">
                <thead><tr><th>#</th><th>Tài liệu</th><th>Lượt trích dẫn</th></tr></thead>
                <tbody>
                    @{ var di = 1; }
                    @foreach (var item in ai.TopRetrievedDocuments)
                    {
                        <tr>
                            <td>@di</td>
                            <td style="font-weight:500;">@item.Name</td>
                            <td><strong>@item.Count</strong></td>
                        </tr>
                        di++;
                    }
                </tbody>
            </table>
        }
        else { <div class="stats-empty">Chưa có trích dẫn.</div> }
    </div>
</div>

@* ── Learning ───────────────────────────────────────────── *@
<h2 class="stats-section-title"><i class="bi bi-mortarboard"></i> Thống kê học tập</h2>
<div class="stats-kpi-row">
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon green"><i class="bi bi-person-walking"></i></div>
        <div>
            <div class="stats-kpi-value">@learn.ActiveUsersLast7Days</div>
            <div class="stats-kpi-label">@(s.Period == "all" ? "Người học (7 ngày)" : "Người học trong kỳ")</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon blue"><i class="bi bi-calendar-week"></i></div>
        <div>
            <div class="stats-kpi-value">@learn.ActiveUsersLast30Days</div>
            <div class="stats-kpi-label">@(s.Period == "all" ? "Người học (30 ngày)" : "Người học trong kỳ")</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon purple"><i class="bi bi-journal-bookmark-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@s.TotalSubjects</div>
            <div class="stats-kpi-label">Tổng môn học</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon amber"><i class="bi bi-chat-left-text"></i></div>
        <div>
            <div class="stats-kpi-value">@(s.TopChatUsers.FirstOrDefault()?.Count ?? 0)</div>
            <div class="stats-kpi-label">Phiên chat nhiều nhất / người dùng</div>
        </div>
    </div>
</div>
<div class="stats-charts-row">
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-clock-history"></i> Thời điểm học nhiều (giờ Việt Nam)</div>
        <div class="stats-chart-wrap"><canvas id="peakHoursChart"></canvas></div>
    </div>
    <div class="stats-table-card">
        <h3><i class="bi bi-trophy"></i> Môn học phổ biến (theo câu hỏi)</h3>
        @if (learn.PopularSubjects.Any())
        {
            <table class="stats-table">
                <thead><tr><th>#</th><th>Môn học</th><th>Câu hỏi</th></tr></thead>
                <tbody>
                    @{ var pi = 1; }
                    @foreach (var item in learn.PopularSubjects)
                    {
                        <tr>
                            <td>@pi</td>
                            <td style="font-weight:500;">@item.Name</td>
                            <td><strong>@item.Count</strong></td>
                        </tr>
                        pi++;
                    }
                </tbody>
            </table>
        }
        else { <div class="stats-empty">Chưa có dữ liệu.</div> }
    </div>
</div>
<div class="stats-tables-row">
    <div class="stats-table-card">
        <h3><i class="bi bi-file-earmark-bar-graph"></i> Số câu hỏi trên mỗi tài liệu</h3>
        @if (learn.QuestionsPerDocument.Any())
        {
            <table class="stats-table">
                <thead><tr><th>#</th><th>Tài liệu</th><th>Câu hỏi</th></tr></thead>
                <tbody>
                    @{ var qi = 1; }
                    @foreach (var item in learn.QuestionsPerDocument)
                    {
                        <tr>
                            <td>@qi</td>
                            <td style="font-weight:500;">@item.Name</td>
                            <td><strong>@item.Count</strong></td>
                        </tr>
                        qi++;
                    }
                </tbody>
            </table>
        }
        else { <div class="stats-empty">Chưa có dữ liệu.</div> }
    </div>
    <div class="stats-table-card">
        <h3><i class="bi bi-people"></i> Người dùng trò chuyện nhiều nhất</h3>
        @if (s.TopChatUsers.Any())
        {
            <table class="stats-table">
                <thead><tr><th>#</th><th>Người dùng</th><th>Phiên</th></tr></thead>
                <tbody>
                    @{ var ci = 1; }
                    @foreach (var u in s.TopChatUsers)
                    {
                        var roleVi = u.Role == "Admin" ? "Quản trị" : u.Role == "Teacher" ? "Giảng viên" : u.Role == "Student" ? "Sinh viên" : u.Role;
                        <tr>
                            <td>@ci</td>
                            <td style="font-weight:500;">@u.DisplayName <span class="stats-role-badge">@roleVi</span></td>
                            <td><strong>@u.Count</strong></td>
                        </tr>
                        ci++;
                    }
                </tbody>
            </table>
        }
        else { <div class="stats-empty">Chưa có dữ liệu.</div> }
    </div>
</div>

@* ── Finance & Tokens ───────────────────────────────────── *@
<h2 class="stats-section-title"><i class="bi bi-cpu"></i> Thống kê token</h2>
<div class="stats-charts-row">
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-bar-chart"></i> Token theo tháng — cột (@s.PeriodLabel)</div>
        <div class="stats-chart-wrap"><canvas id="tokensMonthBarChart"></canvas></div>
    </div>
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-graph-up"></i> Token theo tháng — đường (@s.PeriodLabel)</div>
        <div class="stats-chart-wrap"><canvas id="tokensMonthLineChart"></canvas></div>
    </div>
</div>
<div class="stats-charts-row">
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-bar-chart"></i> Token theo năm — cột</div>
        <div class="stats-chart-wrap"><canvas id="tokensYearBarChart"></canvas></div>
    </div>
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-graph-up"></i> Token theo năm — đường</div>
        <div class="stats-chart-wrap"><canvas id="tokensYearLineChart"></canvas></div>
    </div>
</div>

<h2 class="stats-section-title"><i class="bi bi-wallet2"></i> Doanh thu mua gói (Payment)</h2>
<div class="stats-kpi-row">
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon green"><i class="bi bi-cash-stack"></i></div>
        <div>
            <div class="stats-kpi-value">@s.TotalRevenueInPeriod.ToString("N0")</div>
            <div class="stats-kpi-label">Tổng doanh thu kỳ (đ)</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon teal"><i class="bi bi-calendar-month"></i></div>
        <div>
            <div class="stats-kpi-value">@s.PaymentsByMonth.Count(m => m.Revenue > 0)</div>
            <div class="stats-kpi-label">Số tháng có doanh thu</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon purple"><i class="bi bi-calendar3"></i></div>
        <div>
            <div class="stats-kpi-value">@s.PaymentsByYear.Count(y => y.Revenue > 0)</div>
            <div class="stats-kpi-label">Số năm có doanh thu</div>
        </div>
    </div>
</div>
<div class="stats-charts-row">
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-bar-chart"></i> Doanh thu theo tháng — cột (VNĐ)</div>
        <div class="stats-chart-wrap"><canvas id="payMonthBarChart"></canvas></div>
    </div>
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-graph-up"></i> Doanh thu theo tháng — đường (VNĐ)</div>
        <div class="stats-chart-wrap"><canvas id="payMonthLineChart"></canvas></div>
    </div>
</div>
<div class="stats-charts-row">
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-bar-chart"></i> Doanh thu theo năm — cột (VNĐ)</div>
        <div class="stats-chart-wrap"><canvas id="payYearBarChart"></canvas></div>
    </div>
    <div class="stats-chart-card">
        <div class="stats-chart-title"><i class="bi bi-graph-up"></i> Doanh thu theo năm — đường (VNĐ)</div>
        <div class="stats-chart-wrap"><canvas id="payYearLineChart"></canvas></div>
    </div>
</div>
<div class="stats-tables-row">
    <div class="stats-table-card">
        <h3><i class="bi bi-calendar3"></i> Doanh thu theo tháng</h3>
        @{
            var monthsWithRevenue = s.PaymentsByMonth.Where(m => m.Revenue > 0).OrderByDescending(m => m.Year).ThenByDescending(m => m.Month).ToList();
        }
        @if (monthsWithRevenue.Any())
        {
            <div style="max-height: 360px; overflow-y: auto;">
                <table class="stats-table">
                    <thead>
                        <tr>
                            <th>Tháng</th>
                            <th>Số giao dịch</th>
                            <th>Doanh thu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var month in monthsWithRevenue)
                        {
                            <tr>
                                <td style="font-weight:600;">@month.Label</td>
                                <td>@month.TransactionCount</td>
                                <td style="color:#16a34a; font-weight:700;">@month.Revenue.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else { <div class="stats-empty">Chưa có doanh thu trong kỳ này.</div> }
    </div>
    <div class="stats-table-card">
        <h3><i class="bi bi-person-lines-fill"></i> Chi tiết user: token &amp; mua gói</h3>
        @if (s.UserPaymentStats.Any())
        {
            <div style="max-height: 360px; overflow-y: auto;">
                <table class="stats-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Người dùng</th>
                            <th>Gói hiện tại</th>
                            <th>Token đã dùng</th>
                            <th>Tiền mua gói</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var payIdx = 1; }
                        @foreach (var user in s.UserPaymentStats)
                        {
                            <tr>
                                <td>@payIdx</td>
                                <td style="font-weight:500;">
                                    @user.FullName
                                    <div style="font-size:0.75rem;color:var(--text-muted);">@user.Email</div>
                                </td>
                                <td><span class="badge" style="background:var(--accent);color:#fff;padding:4px 8px;border-radius:4px;">@user.CurrentPlan</span></td>
                                <td style="font-weight:700;color:#7c3aed;">@user.TotalTokensUsed.ToString("N0")</td>
                                <td style="color:#16a34a; font-weight:700;">@user.TotalMoneySpent.ToString("N0") đ</td>
                            </tr>
                            payIdx++;
                        }
                    </tbody>
                </table>
            </div>
        }
        else { <div class="stats-empty">Chưa có dữ liệu người dùng.</div> }
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function () {
    function doughnut(id, labels, data, colors) {
        const el = document.getElementById(id);
        if (!el) return;
        new Chart(el, {
            type: 'doughnut',
            data: {
                labels,
                datasets: [{
                    data,
                    backgroundColor: colors.map(c => c + 'BF'),
                    borderColor: colors,
                    borderWidth: 1.5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, padding: 14 } } }
            }
        });
    }

    function bar(id, labels, data, color) {
        const el = document.getElementById(id);
        if (!el) return;
        new Chart(el, {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    data,
                    backgroundColor: color + 'B3',
                    borderColor: color,
                    borderWidth: 1,
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                plugins: { legend: { display: false } }
            }
        });
    }

    doughnut('roleChart',
        ['Quản trị', 'Giảng viên', 'Sinh viên'],
        [@s.AdminCount, @s.TeacherCount, @s.StudentCount],
        ['#7c3aed', '#0d9488', '#2563eb']);

    const regData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        s.RegistrationsByMonth.Select(m => new { label = m.Label, count = m.Count }).ToList()));
    const regCtx = document.getElementById('regChart');
    if (regCtx && regData) {
        new Chart(regCtx, {
            type: 'line',
            data: {
                labels: regData.map(m => m.label),
                datasets: [{
                    data: regData.map(m => m.count),
                    borderColor: '#2563eb',
                    backgroundColor: 'rgba(37, 99, 235, 0.12)',
                    fill: true,
                    tension: 0.3,
                    borderWidth: 2,
                    pointRadius: 4,
                    pointBackgroundColor: '#2563eb'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                plugins: { legend: { display: false } }
            }
        });
    }

    bar('docStatusChart',
        ['Chờ xử lý', 'Đang xử lý', 'Đã lập chỉ mục', 'Thất bại'],
        [@kb.PendingDocuments, @kb.ProcessingDocuments, @kb.IndexedDocuments, @kb.FailedDocuments],
        '#2563eb');

    doughnut('contextChart',
        ['Có ngữ cảnh', 'Không ngữ cảnh'],
        [@ai.AnswersWithContext, @ai.AnswersWithoutContext],
        ['#16a34a', '#dc2626']);

    const peakData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        learn.PeakHours.Select(h => new { label = h.Label, count = h.Count }).ToList()));
    bar('peakHoursChart',
        peakData.map(h => h.label),
        peakData.map(h => h.count),
        '#0d9488');

    const tokensMonthData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        s.TokensByMonth.Select(m => new { label = m.Label, count = m.Count }).ToList()));
    const tokensYearData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        s.TokensByYear.Select(m => new { label = m.Label, count = m.Count }).ToList()));
    const payMonthData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        s.PaymentsByMonth.Select(m => new { label = m.Label, revenue = m.Revenue }).ToList()));
    const payYearData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        s.PaymentsByYear.Select(m => new { label = m.Label, revenue = m.Revenue }).ToList()));

    function makeBarChart(id, labels, values, color, valueLabel, money) {
        const el = document.getElementById(id);
        if (!el) return;
        new Chart(el, {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    label: valueLabel,
                    data: values,
                    backgroundColor: color + 'B3',
                    borderColor: color,
                    borderWidth: 1,
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: money
                            ? { callback: v => Number(v).toLocaleString('vi-VN') }
                            : { precision: 0, callback: v => Number(v).toLocaleString('vi-VN') }
                    }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: item => valueLabel + ': ' + Number(item.raw).toLocaleString('vi-VN') + (money ? ' đ' : '')
                        }
                    }
                }
            }
        });
    }

    function makeLineChart(id, labels, values, color, valueLabel, money) {
        const el = document.getElementById(id);
        if (!el) return;
        new Chart(el, {
            type: 'line',
            data: {
                labels,
                datasets: [{
                    label: valueLabel,
                    data: values,
                    borderColor: color,
                    backgroundColor: color + '1F',
                    fill: true,
                    tension: 0.3,
                    borderWidth: 2,
                    pointRadius: 4,
                    pointBackgroundColor: color
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: money
                            ? { callback: v => Number(v).toLocaleString('vi-VN') }
                            : { precision: 0, callback: v => Number(v).toLocaleString('vi-VN') }
                    }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: item => valueLabel + ': ' + Number(item.raw).toLocaleString('vi-VN') + (money ? ' đ' : '')
                        }
                    }
                }
            }
        });
    }

    makeBarChart('tokensMonthBarChart', tokensMonthData.map(m => m.label), tokensMonthData.map(m => m.count), '#7c3aed', 'Token', false);
    makeLineChart('tokensMonthLineChart', tokensMonthData.map(m => m.label), tokensMonthData.map(m => m.count), '#7c3aed', 'Token', false);
    makeBarChart('tokensYearBarChart', tokensYearData.map(m => m.label), tokensYearData.map(m => m.count), '#9333ea', 'Token', false);
    makeLineChart('tokensYearLineChart', tokensYearData.map(m => m.label), tokensYearData.map(m => m.count), '#9333ea', 'Token', false);

    makeBarChart('payMonthBarChart', payMonthData.map(m => m.label), payMonthData.map(m => m.revenue), '#16a34a', 'Doanh thu', true);
    makeLineChart('payMonthLineChart', payMonthData.map(m => m.label), payMonthData.map(m => m.revenue), '#16a34a', 'Doanh thu', true);
    makeBarChart('payYearBarChart', payYearData.map(m => m.label), payYearData.map(m => m.revenue), '#0d9488', 'Doanh thu', true);
    makeLineChart('payYearLineChart', payYearData.map(m => m.label), payYearData.map(m => m.revenue), '#0d9488', 'Doanh thu', true);
})();
</script>
}
