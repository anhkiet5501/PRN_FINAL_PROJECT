@page
@model PresentationLayer.Pages.Admin.Subscriptions.IndexModel
@{
    ViewData["Title"] = "Quản lý Người đăng ký";
    ViewData["ActivePage"] = "Subscriptions";
}

<style>
.stats-kpi-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.25rem;
}
.stats-kpi-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    box-shadow: var(--shadow);
    display: flex;
    align-items: center;
    gap: 0.85rem;
}
.stats-kpi-icon {
    width: 42px; height: 42px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.15rem;
    flex-shrink: 0;
}
.stats-kpi-icon.blue   { background: #eff6ff; color: #2563eb; }
.stats-kpi-icon.amber  { background: #fffbeb; color: #d97706; }
.stats-kpi-icon.purple { background: #faf5ff; color: #7c3aed; }
.stats-kpi-icon.teal   { background: #f0fdfa; color: #0d9488; }
.stats-kpi-value { font-size: 1.55rem; font-weight: 800; color: var(--text); line-height: 1; }
.stats-kpi-label { font-size: 0.72rem; color: var(--text-muted); font-weight: 500; margin-top: 0.2rem; text-transform: uppercase; }

@@media (max-width: 960px) {
    .stats-kpi-row { grid-template-columns: repeat(2, 1fr); }
}
@@media (max-width: 560px) {
    .stats-kpi-row { grid-template-columns: 1fr; }
}
</style>

<div class="page-header-row">
    <h1 class="dashboard-title" style="margin-bottom:0;">QUẢN LÝ NGƯỜI ĐĂNG KÝ</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="stats-kpi-row">
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon teal"><i class="bi bi-people-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@Model.TotalStudents</div>
            <div class="stats-kpi-label">Tổng sinh viên</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon blue"><i class="bi bi-person-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@Model.BasicCount</div>
            <div class="stats-kpi-label">Basic</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon purple"><i class="bi bi-star-fill"></i></div>
        <div>
            <div class="stats-kpi-value">@Model.ProCount</div>
            <div class="stats-kpi-label">Pro</div>
        </div>
    </div>
    <div class="stats-kpi-card">
        <div class="stats-kpi-icon amber"><i class="bi bi-stars"></i></div>
        <div>
            <div class="stats-kpi-value">@Model.UltraCount</div>
            <div class="stats-kpi-label">Ultra</div>
        </div>
    </div>
</div>

<div class="brutalist-table-container">
    <table class="brutalist-table">
        <thead>
            <tr>
                <th>Người dùng</th>
                <th>Email</th>
                <th>Gói</th>
                <th>Hết hạn</th>
                <th>Lượt 5 giờ</th>
                <th>Lượt tháng</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Students)
            {
                <tr>
                    <td style="font-weight: 500;">@user.Username</td>
                    <td>@(string.IsNullOrEmpty(user.Email) ? "-" : user.Email)</td>
                    <td>
                        @if (user.SubscriptionPlan == "Basic" || user.SubscriptionPlan == "Free")
                        {
                            <span style="display:inline-block; padding: 2px 8px; border-radius: 4px; border: 1px solid #93c5fd; font-size: 0.8rem; font-weight: 600; color: #1e40af; background: #eff6ff;">
                                <i class="bi bi-person"></i> BASIC
                            </span>
                        }
                        else if (user.SubscriptionPlan == "Pro")
                        {
                            <span style="display:inline-block; padding: 2px 8px; border-radius: 4px; border: 1px solid #c4b5fd; font-size: 0.8rem; font-weight: 600; color: #5b21b6; background: #f5f3ff;">
                                <i class="bi bi-star-fill"></i> PRO
                            </span>
                        }
                        else
                        {
                            <span style="display:inline-block; padding: 2px 8px; border-radius: 4px; border: 1px solid #fde047; font-size: 0.8rem; font-weight: 600; color: #854d0e; background: #fefce8;">
                                <i class="bi bi-stars"></i> ULTRA
                            </span>
                        }
                    </td>
                    <td>
                        @(user.SubscriptionExpiry.HasValue ? user.SubscriptionExpiry.Value.ToString("dd/MM/yyyy") : "-")
                    </td>
                    <td>
                        @{
                            var shortLimit = user.SubscriptionPlan == "Ultra" ? 1000 : (user.SubscriptionPlan == "Pro" ? 50 : 10);
                        }
                        <div style="font-size:0.8rem;">Còn @(shortLimit - user.ShortTermQuestionCount) / @shortLimit</div>
                        <div style="width:100px; height:6px; background:#e2e8f0; border-radius:3px; margin-top:4px;">
                            <div style="height:100%; border-radius:3px; background:#10b981; width:@Math.Max(0, (shortLimit - user.ShortTermQuestionCount) * 100 / Math.Max(1, shortLimit))%;"></div>
                        </div>
                    </td>
                    <td>
                        @{
                            var monthLimit = user.SubscriptionPlan == "Ultra" ? 5000 : (user.SubscriptionPlan == "Pro" ? 200 : 50);
                        }
                        <div style="font-size:0.8rem;">Còn @(monthLimit - user.MonthlyQuestionCount) / @monthLimit</div>
                        <div style="width:100px; height:6px; background:#e2e8f0; border-radius:3px; margin-top:4px;">
                            <div style="height:100%; border-radius:3px; background:#10b981; width:@Math.Max(0, (monthLimit - user.MonthlyQuestionCount) * 100 / Math.Max(1, monthLimit))%;"></div>
                        </div>
                    </td>
                    <td>
                        <div style="display: flex; gap: 0.5rem;">
                            <button type="button" class="btn-action btn-action-detail" onclick="showEditModal(@user.UserId, '@user.Username', '@user.SubscriptionPlan')">
                                <i class="bi bi-pencil-square"></i> SỬA GÓI
                            </button>
                            <form method="post" asp-page-handler="ResetQuota" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn reset lượt hỏi?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.UserId" />
                                <button type="submit" class="btn-action btn-action-edit">
                                    <i class="bi bi-arrow-counterclockwise"></i> RESET
                                </button>
                            </form>
                            <form method="post" asp-page-handler="RevokePlan" style="display:inline;" onsubmit="return confirm('Thu hồi gói (Về Basic)?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.UserId" />
                                <button type="submit" class="btn-action btn-action-delete">
                                    <i class="bi bi-ban"></i> THU HỒI
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Edit Plan Modal -->
<div id="edit-modal" class="modal-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center;">
    <div class="modal-content" style="background:#fff; padding:1.5rem; border-radius:8px; width:400px; max-width:90%;">
        <h3 style="margin-top:0; margin-bottom:1rem; font-size:1.1rem;"><i class="bi bi-pencil"></i> Cập nhật gói</h3>
        <form method="post" asp-page-handler="EditPlan">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" id="editUserId" />
            <div class="form-group" style="margin-bottom:1rem;">
                <label style="display:block; margin-bottom:0.5rem; font-weight:600; font-size:0.9rem;">Người dùng</label>
                <input type="text" id="editUsername" class="form-control" style="width:100%; padding:0.5rem; border:1px solid #ccc; border-radius:4px;" readonly />
            </div>
            <div class="form-group" style="margin-bottom:1rem;">
                <label style="display:block; margin-bottom:0.5rem; font-weight:600; font-size:0.9rem;">Gói (Plan)</label>
                <select name="plan" id="editPlan" class="form-control" style="width:100%; padding:0.5rem; border:1px solid #ccc; border-radius:4px;" required>
                    <option value="Basic">Basic</option>
                    <option value="Pro">Pro</option>
                    <option value="Ultra">Ultra</option>
                </select>
            </div>
            <div style="display:flex; gap:0.5rem; justify-content:flex-end; margin-top:1.5rem;">
                <button type="button" class="soft-btn btn-light" onclick="hideEditModal()">Huỷ</button>
                <button type="submit" class="soft-btn btn-primary">Cập nhật</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function showEditModal(id, username, plan) {
        document.getElementById('editUserId').value = id;
        document.getElementById('editUsername').value = username;
        document.getElementById('editPlan').value = plan;
        document.getElementById('edit-modal').style.display = 'flex';
    }
    function hideEditModal() {
        document.getElementById('edit-modal').style.display = 'none';
    }
</script>
}
