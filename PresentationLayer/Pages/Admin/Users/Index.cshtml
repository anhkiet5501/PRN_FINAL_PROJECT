@page
@model PRN222_Assignment2.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Quản lý Người dùng";
    ViewData["ActivePage"] = "Users";
}

<div class="page-header-row">
    <h1 class="dashboard-title" style="margin-bottom:0;">QUẢN LÝ NGƯỜI DÙNG</h1>
    <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
        <button class="soft-btn btn-primary" onclick="showCreateModal()"><i class="bi bi-person-plus"></i> THÊM NGƯỜI DÙNG</button>
        <button class="soft-btn btn-warm"><i class="bi bi-send"></i> GỬI THÔNG BÁO</button>
        <button class="soft-btn btn-light" onclick="showImportModal()"><i class="bi bi-file-earmark-arrow-up"></i> IMPORT CSV</button>
    </div>
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null)
{ <div class="alert alert-error">@TempData["Error"]</div> }

<div class="brutalist-table-container">
    <table class="brutalist-table">
        <thead>
            <tr>
                <th style="width: 40px; text-align: center;">[x]</th>
                <th>Họ và Tên</th>
                <th>Email</th>
                <th>Vai Trò</th>
                <th>Token đã dùng</th>
                <th>Trạng Thái</th>
                <th>Hành Động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td style="text-align: center;"><input type="checkbox" style="cursor:pointer;" /></td>
                    <td style="font-weight: 500;">@(string.IsNullOrEmpty(user.FullName) ? user.Username : user.FullName)</td>
                    <td>@user.Email</td>
                    <td>@(user.Role == "Admin" ? "ADMIN" : user.Role == "Teacher" ? "Giảng viên" : "Sinh viên")</td>
                    <td style="font-variant-numeric: tabular-nums;">@user.TokensUsed.ToString("N0")</td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="status-text-active"><span class="status-dot status-active"></span> Hoạt động</span>
                        }
                        else
                        {
                            <span class="status-text-inactive"><span class="status-dot status-inactive"></span> Bị khóa</span>
                        }
                    </td>
                    <td>
                        <div style="display: flex; gap: 0.5rem;">
                            <button type="button" class="btn-action btn-action-edit" title="Sửa" onclick="showEditModal(@user.UserId, '@user.FullName', '@user.Role')">
                                <i class="bi bi-pencil"></i> SỬA
                            </button>
                            @if (user.Role != "Admin")
                            {
                                <form method="post" asp-page-handler="DeleteUser" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa người dùng này?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    <button type="submit" class="btn-action btn-action-delete" title="Xóa">
                                        <i class="bi bi-trash"></i> XÓA
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Import CSV Modal -->
<div id="import-modal" class="modal-overlay">
    <div class="modal-content">
        <h3 class="modal-title">Import CSV Users</h3>
        <p style="font-size:0.875rem; color:#6c757d; margin-bottom:1rem;">
            File CSV cần có các cột Header: <strong>Username, Email, FullName, Role, Password</strong>.
            Nếu Password bỏ trống, hệ thống sẽ tự sinh và gửi qua Email.
        </p>
        <form method="post" asp-page-handler="ImportCsv" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">File CSV</label>
                <input type="file" name="CsvFile" class="form-control" accept=".csv" required />
            </div>
            <div style="display:flex; gap:0.5rem; justify-content:flex-end;">
                <button type="button" class="btn btn-secondary" onclick="hideImportModal()">Huỷ</button>
                <button type="submit" class="btn btn-success">Import</button>
            </div>
        </form>
    </div>
</div>

<!-- Create User Modal -->
<div id="create-modal" class="modal-overlay">
    <div class="modal-content">
        <h3 class="modal-title">+ Thêm người dùng mới</h3>
        <form method="post" asp-page-handler="CreateUser">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label class="form-label">Tên đăng nhập</label>
                <input type="text" name="Input.Username" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">Email</label>
                <input type="email" name="Input.Email" class="form-control" required />
            </div>
            <div class="form-group">
                <label class="form-label">Họ tên</label>
                <input type="text" name="Input.FullName" class="form-control" />
            </div>
            <div class="grid-2">
                <div class="form-group">
                    <label class="form-label">Mật khẩu</label>
                    <input type="password" name="Input.Password" class="form-control" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Vai trò (Role)</label>
                    <select name="Input.Role" class="form-control" required>
                        <option value="Student">Student</option>
                        <option value="Teacher">Teacher</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
            </div>
            <div style="display:flex; gap:0.5rem; justify-content:flex-end;">
                <button type="button" class="btn btn-secondary" onclick="hideCreateModal()">Huỷ</button>
                <button type="submit" class="btn btn-primary">Tạo</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit User Modal -->
<div id="edit-modal" class="modal-overlay">
    <div class="modal-content">
        <h3 class="modal-title"><i class="bi bi-pencil"></i> Cập nhật thông tin</h3>
        <form method="post" asp-page-handler="EditUser">
            @Html.AntiForgeryToken()
            <input type="hidden" name="editUserId" id="editUserId" />
            <div class="form-group">
                <label class="form-label">Họ tên</label>
                <input type="text" name="UpdateInput.FullName" id="editFullName" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Vai trò (Role)</label>
                <select name="UpdateInput.Role" id="editRole" class="form-control" required>
                    <option value="Student">Sinh viên</option>
                    <option value="Teacher">Giảng viên</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            <div style="display:flex; gap:0.5rem; justify-content:flex-end;">
                <button type="button" class="btn btn-secondary" onclick="hideEditModal()">Huỷ</button>
                <button type="submit" class="btn btn-primary">Cập nhật</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function showImportModal() { document.getElementById('import-modal').classList.add('show'); }
    function hideImportModal() { document.getElementById('import-modal').classList.remove('show'); }
    document.getElementById('import-modal').addEventListener('click', function(e) { if (e.target === this) hideImportModal(); });

    function showCreateModal() { document.getElementById('create-modal').classList.add('show'); }
    function hideCreateModal() { document.getElementById('create-modal').classList.remove('show'); }
    document.getElementById('create-modal').addEventListener('click', function(e) { if (e.target === this) hideCreateModal(); });
    
    function showEditModal(id, name, role) {
        document.getElementById('editUserId').value = id;
        document.getElementById('editFullName').value = name;
        document.getElementById('editRole').value = role;
        document.getElementById('edit-modal').classList.add('show');
    }
    function hideEditModal() { document.getElementById('edit-modal').classList.remove('show'); }
    document.getElementById('edit-modal').addEventListener('click', function(e) { if (e.target === this) hideEditModal(); });
</script>
}
