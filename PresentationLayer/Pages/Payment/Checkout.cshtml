@page
@model CheckoutModel
@{
    ViewData["Title"] = "Thanh toán gói Chatbox";
}

<div class="container mt-5">
    <div class="py-5 text-center">
        <h2>Thanh toán dịch vụ</h2>
        <p class="lead">Nâng cấp tài khoản Chatbox Hỗ Trợ Học Tập để mở khóa các tính năng giải toán, viết văn và hỏi đáp không giới hạn.</p>
    </div>

    <div class="row">
        <!-- Tóm tắt gói dịch vụ (Cột bên phải) -->
        <div class="col-md-4 order-md-2 mb-4">
            <h4 class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted">Chi tiết đơn hàng</span>
            </h4>
            <ul class="list-group mb-3">
                <li class="list-group-item d-flex justify-content-between lh-condensed">
                    <div>
                        <h6 class="my-0">Gói Chatbox Pro (1 Tháng)</h6>
                        <small class="text-muted">Hỗ trợ bằng AI nâng cao (GPT-4)</small>
                    </div>
                    <span class="text-muted">99.000đ</span>
                </li>
                <li class="list-group-item d-flex justify-content-between bg-light">
                    <div class="text-success">
                        <h6 class="my-0">Mã khuyến mãi</h6>
                        <small>HOCSINH20</small>
                    </div>
                    <span class="text-success">-19.800đ</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>Tổng thanh toán (VND)</span>
                    <strong>79.200đ</strong>
                </li>
            </ul>
        </div>

        <!-- Form điền thông tin (Cột bên trái) -->
        <div class="col-md-8 order-md-1">
            <h4 class="mb-3">Thông tin tài khoản</h4>
            
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Input.FullName">Họ và tên</label>
                        <input asp-for="Input.FullName" class="form-control" placeholder="Nguyễn Văn A" />
                        <span asp-validation-for="Input.FullName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Input.PhoneNumber">Số điện thoại</label>
                        <input asp-for="Input.PhoneNumber" class="form-control" placeholder="0901234567" />
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Email">Email <span class="text-muted">(Dùng để đăng nhập & nhận biên lai)</span></label>
                    <input asp-for="Input.Email" type="email" class="form-control" placeholder="you@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <hr class="mb-4">
                <h4 class="mb-3">Phương thức thanh toán</h4>

                <div class="d-block my-3">
                    <div class="custom-control custom-radio mb-2">
                        <input id="momo" name="paymentMethod" type="radio" class="custom-control-input" checked required>
                        <label class="custom-control-label" for="momo">Ví điện tử MoMo</label>
                    </div>
                    <div class="custom-control custom-radio mb-2">
                        <input id="vietqr" name="paymentMethod" type="radio" class="custom-control-input" required>
                        <label class="custom-control-label" for="vietqr">Chuyển khoản Ngân hàng (Quét mã VietQR)</label>
                    </div>
                    <div class="custom-control custom-radio">
                        <input id="credit" name="paymentMethod" type="radio" class="custom-control-input" required>
                        <label class="custom-control-label" for="credit">Thẻ thanh toán quốc tế (Visa/Mastercard)</label>
                    </div>
                </div>

                <hr class="mb-4">
                <button class="btn btn-primary btn-lg btn-block" type="submit">Thanh toán & Kích hoạt gói</button>
            </form>
        </div>
    </div>
</div>

<!-- Kích hoạt script validate ở phía Client -->
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}