@page
@model PresentationLayer.Pages.Payment.VNPayReturnModel
@{
    ViewData["Title"] = "Kết quả thanh toán";
    ViewData["ActivePage"] = "Subscription";
}

<div class="card" style="max-width:560px; margin:2rem auto; padding:2rem; text-align:center;">
    @if (Model.IsSuccess)
    {
        <div style="font-size:3rem; color:#059669; margin-bottom:1rem;"><i class="bi bi-check-circle-fill"></i></div>
        <h2 style="margin-bottom:0.75rem;">Thanh toán thành công</h2>
        <p style="color:var(--text-muted); margin-bottom:1.5rem;">@Model.Message</p>
        @if (!string.IsNullOrEmpty(Model.PlanCode))
        {
            <p>Gói <strong>@Model.PlanCode</strong> đã được kích hoạt.</p>
        }
    }
    else
    {
        <div style="font-size:3rem; color:#dc2626; margin-bottom:1rem;"><i class="bi bi-x-circle-fill"></i></div>
        <h2 style="margin-bottom:0.75rem;">Thanh toán thất bại</h2>
        <p style="color:var(--text-muted); margin-bottom:1.5rem;">@Model.Message</p>
    }
    <div style="display:flex; gap:0.75rem; justify-content:center; margin-top:1.5rem;">
        <a href="/Subscription" class="soft-btn btn-primary">Quay lại gói đăng ký</a>
        <a href="/Chat" class="soft-btn btn-light">Mở Chat AI</a>
    </div>
</div>
