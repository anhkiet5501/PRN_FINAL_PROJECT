@page
@model VNPayReturnModel
@{
    ViewData["Title"] = "Kết quả thanh toán VNPay";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            
            @if (Model.IsSuccess)
            {
                <div class="alert alert-success p-5" role="alert">
                    <h2 class="alert-heading mb-4"><i class="bi bi-check-circle-fill"></i> Thanh toán thành công!</h2>
                    <p class="lead">Cảm ơn bạn đã đăng ký gói Chatbox Hỗ Trợ Học Tập. Tài khoản của bạn đã được nâng cấp.</p>
                    <hr>
                    <div class="text-left mt-4" style="max-width: 400px; margin: 0 auto;">
                        <p><strong>Mã đơn hàng:</strong> @Model.OrderId</p>
                        <p><strong>Mã giao dịch VNPay:</strong> @Model.TransactionId</p>
                        <p><strong>Số tiền:</strong> @Model.Amount VND</p>
                    </div>
                    <a href="/Chatbox" class="btn btn-success btn-lg mt-4">Trải nghiệm Chatbox ngay</a>
                </div>
            }
            else
            {
                <div class="alert alert-danger p-5" role="alert">
                    <h2 class="alert-heading mb-4"><i class="bi bi-x-circle-fill"></i> Thanh toán thất bại!</h2>
                    <p class="lead">Giao dịch không thành công hoặc đã bị hủy.</p>
                    <hr>
                    <p class="mb-0"><strong>Lý do/Mã lỗi:</strong> @Model.Message</p>
                    <a href="/Checkout" class="btn btn-outline-danger btn-lg mt-4">Thử thanh toán lại</a>
                </div>
            }

        </div>
    </div>
</div>