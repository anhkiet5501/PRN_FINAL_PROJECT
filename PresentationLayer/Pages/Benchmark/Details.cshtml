@page "{experimentId:int}"
@model PRN222_Assignment2.Pages.Benchmark.DetailsModel
@{
    ViewData["Title"] = "Chi tiết Benchmark";
    ViewData["ActivePage"] = "Benchmark";
}

<div class="page-header">
    <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
        <div>
            <h1>Kết quả Benchmark</h1>
            <p>Chi tiết kết quả đánh giá (Faithfulness & Relevance)</p>
        </div>
        <a href="/Benchmark?subjectId=@Model.SubjectId" class="btn btn-secondary">← Trở về</a>
    </div>
</div>

<div class="grid-2">
    <div class="card">
        <h3 style="margin-bottom:0.75rem;">Tóm tắt Kết quả</h3>
        @if (Model.Results.Any())
        {
            var avgF = Model.Results.Average(r => (double?)r.FaithfulnessScore) ?? 0;
            var avgR = Model.Results.Average(r => (double?)r.RelevanceScore) ?? 0;
            var avgLat = Model.Results.Average(r => (double?)r.LatencyMs) ?? 0;
            <div style="display:flex; gap:2rem;">
                <div>
                    <div style="color:#6c757d; font-size:0.8rem;">Faithfulness</div>
                    <div style="font-size:1.75rem; font-weight:700; color:#198754;">@avgF.ToString("P1")</div>
                </div>
                <div>
                    <div style="color:#6c757d; font-size:0.8rem;">Relevance</div>
                    <div style="font-size:1.75rem; font-weight:700; color:#0d6efd;">@avgR.ToString("P1")</div>
                </div>
                <div>
                    <div style="color:#6c757d; font-size:0.8rem;">Avg Latency</div>
                    <div style="font-size:1.75rem; font-weight:700; color:#333;">@avgLat.ToString("F0") ms</div>
                </div>
            </div>
        }
        else
        {
            <p style="color:#6c757d;">Experiment chưa được chạy hoặc không có dữ liệu.</p>
        }
    </div>
</div>

<h3 style="margin-top:1.5rem; margin-bottom:0.75rem;">Chi tiết Test Cases</h3>
<div style="display:flex; flex-direction:column; gap:0.75rem;">
    @foreach (var result in Model.Results)
    {
        <div class="card" style="margin-bottom:0;">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                <div>
                    <div style="font-weight:600; color:#6c757d; margin-bottom:0.35rem; font-size:0.8rem;">Q: @result.Question</div>
                    <div style="font-size:0.875rem; color:#084298; background-color:#cfe2ff; padding:0.6rem; border-radius:4px; border:1px solid #b6d4fe;">
                        <strong>Expected:</strong><br/> @result.ExpectedAnswer
                    </div>
                </div>
                <div>
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.35rem;">
                        <div style="font-size:0.8rem; font-weight:600; color:#6c757d;">AI Generated Answer</div>
                        <div style="display:flex; gap:0.5rem; font-size:0.75rem;">
                            <span style="color:#198754;">F: @(result.FaithfulnessScore?.ToString("P1") ?? "-")</span>
                            <span style="color:#0d6efd;">R: @(result.RelevanceScore?.ToString("P1") ?? "-")</span>
                            <span style="color:#6c757d;">@result.LatencyMs ms</span>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(result.ErrorMessage))
                    {
                        <div style="font-size:0.875rem; color:#842029; background-color:#f8d7da; padding:0.6rem; border-radius:4px; border:1px solid #f5c2c7;">
                            <strong>Lỗi:</strong> @result.ErrorMessage
                        </div>
                    }
                    else
                    {
                        <div style="font-size:0.875rem; background-color:#f8f9fa; padding:0.6rem; border-radius:4px; border:1px solid #dee2e6;">
                            @result.GeneratedAnswer
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    @if (!Model.Results.Any())
    {
        <div class="card" style="text-align:center; padding:2rem; color:#6c757d;">
            Chưa có kết quả. Bạn cần thêm Test Case và chạy (Run) Experiment.
        </div>
    }
</div>

<!-- Add Test Case -->
<div class="card" style="margin-top:1.5rem;">
    <h3 style="margin-bottom:0.75rem;">+ Thêm Test Case Mới</h3>
    <form method="post" asp-page-handler="AddTestCase">
        @Html.AntiForgeryToken()
        <div class="grid-2">
            <div class="form-group">
                <label class="form-label">Câu hỏi (Question)</label>
                <textarea name="TestCaseInput.Question" class="form-control" rows="3" required></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">Câu trả lời mẫu (Expected Answer)</label>
                <textarea name="TestCaseInput.ExpectedAnswer" class="form-control" rows="3" required></textarea>
            </div>
        </div>
        <div style="display:flex; justify-content:flex-end;">
            <button type="submit" class="btn btn-primary">+ Thêm</button>
        </div>
    </form>
</div>
