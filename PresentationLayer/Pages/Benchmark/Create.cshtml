@page
@model PRN222_Assignment2.Pages.Benchmark.CreateModel
@{
    ViewData["Title"] = "Tạo Experiment Mới";
    ViewData["ActivePage"] = "Benchmark";
}

<div class="page-header-row">
    <div>
        <h1 class="dashboard-title" style="margin-bottom:0.25rem;">TẠO EXPERIMENT</h1>
        <p class="page-subtitle" style="margin-bottom:0;">Khởi tạo cấu hình đánh giá (Model, Chunking, Top K)</p>
    </div>
    <a href="/Benchmark" class="soft-btn btn-secondary">← Trở về</a>
</div>

@if (TempData["Error"] != null)
{ <div class="alert alert-error">@TempData["Error"]</div> }

<div class="card" style="max-width:800px;">
    <form method="post">
        @Html.AntiForgeryToken()
        
        <div class="form-group">
            <label class="form-label">Tên Experiment</label>
            <input type="text" name="Input.ExperimentName" class="form-control" required placeholder="VD: Test Gemini + FixedSize 512" />
        </div>

        <div class="form-group">
            <label class="form-label">Mô tả (Không bắt buộc)</label>
            <textarea name="Input.Description" class="form-control" rows="2"></textarea>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label class="form-label">Môn học</label>
                <select name="Input.SubjectId" class="form-control" required>
                    <option value="">-- Chọn môn học --</option>
                    @foreach (var s in Model.Subjects)
                    {
                        <option value="@s.SubjectId">@s.SubjectCode - @s.SubjectName</option>
                    }
                </select>
            </div>
            
            <div class="form-group">
                <label class="form-label">Top K (Số chunk tài liệu trích xuất)</label>
                <input type="number" name="Input.TopK" class="form-control" value="3" min="1" max="10" required />
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label class="form-label">AI Model</label>
                <select name="Input.AiModelId" class="form-control" required>
                    @foreach (var m in Model.AiModels)
                    {
                        <option value="@m.AiModelId">@m.ModelName</option>
                    }
                </select>
            </div>
            
            <div class="form-group">
                <label class="form-label">Embedding Model</label>
                <select name="Input.EmbeddingModelId" class="form-control" required>
                    @foreach (var m in Model.EmbeddingModels)
                    {
                        <option value="@m.EmbeddingModelId">@m.ModelName</option>
                    }
                </select>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Chiến lược Chunking (Phân mảnh tài liệu)</label>
            <select name="Input.ChunkingStrategyId" class="form-control" required>
                @foreach (var s in Model.ChunkingStrategies)
                {
                    <option value="@s.ChunkingStrategyId">@s.StrategyName (Size: @s.ChunkSize, Overlap: @s.ChunkOverlap)</option>
                }
            </select>
            <p style="font-size:0.75rem; color:#6c757d; margin-top:0.25rem;">
                Lưu ý: Môn học phải có ít nhất 1 tài liệu được Index bằng chiến lược & mô hình Embedding này để AI có thể lấy ngữ cảnh.
            </p>
        </div>

        <div style="display:flex; justify-content:flex-end; margin-top:1.5rem;">
            <button type="submit" class="btn btn-primary">Tạo Experiment</button>
        </div>
    </form>
</div>
