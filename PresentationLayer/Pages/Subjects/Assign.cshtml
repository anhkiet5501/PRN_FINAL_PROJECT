@page "{subjectId:int}"
@model PRN222_Assignment2.Pages.Subjects.AssignModel
@{
    ViewData["Title"] = "Phân công Giảng viên";
    ViewData["ActivePage"] = "Subjects";
}

<div class="page-header">
    <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
        <div>
            <h1>Phân công Giảng viên</h1>
            <p>Môn học: <strong>@Model.Subject?.SubjectCode - @Model.Subject?.SubjectName</strong></p>
        </div>
        <a href="/Subjects" class="btn btn-secondary">← Trở về</a>
    </div>
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null)
{ <div class="alert alert-error">@TempData["Error"]</div> }

<div class="card">
    <form method="post">
        @Html.AntiForgeryToken()
        <h3 style="margin-bottom:0.75rem;">Danh sách Giảng viên</h3>
        <p style="color:#6c757d; font-size:0.875rem; margin-bottom:1rem;">
            Chọn các giảng viên sẽ được quyền upload tài liệu và quản lý chunking cho môn học này.
        </p>

        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(250px, 1fr)); gap:0.75rem; margin-bottom:1.5rem;">
            @foreach (var teacher in Model.AllTeachers)
            {
                var isAssigned = Model.AssignedTeacherIds.Contains(teacher.UserId);
                var isHead = Model.HeadTeacherIds.Contains(teacher.UserId);
                <div style="display:flex; flex-direction:column; gap:0.5rem; padding:0.75rem; background:#f8f9fa; border:1px solid #dee2e6; border-radius:4px;">
                    <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
                        <input type="checkbox" name="SelectedTeacherIds" value="@teacher.UserId" @(isAssigned ? "checked" : "") style="width:1.1rem; height:1.1rem;" />
                        <div>
                            <div style="font-weight:600;">@teacher.FullName</div>
                            <div style="font-size:0.75rem; color:#6c757d;">@teacher.Email</div>
                        </div>
                    </label>
                    <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer; margin-left:1.5rem;">
                        <input type="checkbox" name="SelectedHeadTeacherIds" value="@teacher.UserId" @(isHead ? "checked" : "") />
                        <span style="font-size:0.8rem; color:#6c757d;">Trưởng bộ môn</span>
                    </label>
                </div>
            }
            @if (!Model.AllTeachers.Any())
            {
                <p style="color:#6c757d;">Chưa có giảng viên nào trong hệ thống.</p>
            }
        </div>

        <div style="display:flex; justify-content:flex-end;">
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
        </div>
    </form>
</div>
